# Server Configuration
PORT=3000
NODE_ENV=production

# Security
# REPLACE THESE IN YOUR PRIVATE .env FILE
JWT_SECRET=change_this_to_something_random_and_secure
REGISTRATION_CODE=change_me

# Cookie Security
# Set to 'true' if serving over HTTPS (Production)
# Set to 'false' if serving over HTTP (Local/Pi Network)
COOKIE_SECURE=false

# Timezone
TZ=UTC
